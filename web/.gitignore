# ==========================================
# Web-specific (React/Vite) .gitignore
# ==========================================

# Dependencies
node_modules/

# Production builds
dist/
dist-ssr/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Environment and local configurations
*.local
.env.local
.env.*.local

# IDEs, editors & OS files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
